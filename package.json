{
  "name": "croshes-ui",
  "version": "0.1.1",
  "description": "Croshes Design System – React-Komponenten mit Tailwind CSS (AlpakaPro, Alpaca-Store)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JimKnopf90/croshes-ui.git"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "files": [
    "dist",
    "tailwind-preset.cjs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.1.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "react-day-picker": "^9.14.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-themes": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.0",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
